<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_ios_notification"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="10dp">

    <!-- iOS App Icon Badge Concept -->
    <FrameLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_ios_notification"
        android:layout_marginEnd="12dp">
        
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/app_logo_bw_1781709946353"
            android:layout_gravity="center"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <!-- Info Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/noti_event_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COSMOS RIFT"
            android:textColor="#85FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/noti_event_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lunar Base Launch"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Pinned Timer Capsule on Right -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pod"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/noti_countdown_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14d : 08h : 42m"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
